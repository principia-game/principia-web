{% extends "_layout.twig" %}

{% set title = "Download Principia" %}
{% set description = "Download the latest version of Principia for Windows, Linux, Android and more." %}


{% set version = '2026.07.15' %}
{% set dlurl = 'https://github.com/Bithack/principia/releases/download/'~ version %}

	{% block content %}
{% if not is_mobile_ua() %}
	<div class="header_message">
		<p>
			Want to try Principia without installing anything?
			Check out the new <a href="/play">web version</a> of Principia, which runs right in your browser!
		</p>

		<p>
			You can also play any level on the community site right in your browser by selecting the web version when pressing Play.
		</p>
	</div>
{% endif %}

<h1>Download Principia</h1>

<p>
	The latest version of Principia is <strong>{{ version }}</strong>.
	You can see what is new in this release in the <a href="/wiki/Changelog#{{ version }}">Changelog</a>.
</p>

<p>
	<strong>Problems</strong>, <em>crashes</em> or <u>bugs</u>? Ask in <a href="/discord">the Discord server</a>,
	<a href="/matrix">the Matrix space</a> or on <a href="/forum/">the forums</a>, or
	<a href="https://github.com/Bithack/principia/issues">open an issue on Github</a>.
</p>

<table class="dl">

<tr>
	<td class="plat" id="windows">
		<a href="#windows"><img src="/icons/windows.svg"></a><br>Windows
	</td>
	<td colspan="2">
		<p>
			<strong>
				<a href="{{ dlurl }}/principia_{{ version }}_win64.exe">
					Principia {{ version }} for Windows - Installer, 64-bit (recommended)
				</a>
			</strong>
		</p>

		<p>
			<a href="{{ dlurl }}/principia_{{ version }}_win64.7z">
				Principia {{ version }} for Windows - Portable, 64-bit
			</a>
		</p>

		<p>
			Windows 10 and above is supported, older versions may work but are not supported.
			The portable build has some limitations to it that are important to know about, see <a href="/wiki/Windows_Portable">Windows Portable</a> for more info.
		</p>
	</td>
</tr>

<tr>
	<td class="plat" id="android">
		<a href="#android"><img src="/icons/android.svg?v=2"></a><br>Android
	</td>
	<td colspan="2">
		<p>
			<strong>
				<a href="{{ dlurl }}/principia_{{ version }}.apk">
					Principia {{ version }} for Android 5.0+ - Direct APK download
				</a>
			</strong>
		</p>

		<p>
			Principia is also available on F-Droid:
		</p>

		<p>
			<a href="https://f-droid.org/packages/com.bithack.principia/">
				<img src="/assets/fdroid.png" alt="Get it on F-Droid" height="80">
			</a>
		</p>

		<p>
			Keep in mind that the F-Droid build uses a different signing key, which means that if you want to switch distribution channels you'll need to fully uninstall Principia before installing the new version. Please back up your user data before doing so.
		</p>
	</td>
</tr>

<tr>
	<td class="plat" rowspan="7" id="linux">
		<a href="#linux"><img src="/icons/linux.svg?v=2"></a><br>Linux
	</td>
</tr>

<tr>
	<td class="plat" id="appimage">
		<a href="#appimage"><img src="/icons/appimage.svg"></a><br>AppImage
	</td>
	<td>
		<p>
			<strong>
				<a href="{{ dlurl }}/principia_{{ version }}_x86_64.AppImage">
					Principia {{ version }} for Linux - AppImage, 64-bit
				</a>
			</strong>
		</p>

		<p>
			A glibc-based distro equivalent to Debian 11 Bullseye or newer is required. <strong>GTK3</strong>, <strong>xdg-utils</strong> and functional OpenGL drivers need to be installed.
		</p>

		<p>
			How to run an AppImage? See
			<a href="https://docs.appimage.org/introduction/quickstart.html#ref-how-to-run-appimage">
				AppImage quickstart</a>.
		</p>
	</td>
</tr>

<tr>
	<td class="plat" id="archlinux">
		<a href="#archlinux"><img src="/icons/arch.svg"></a><br>Arch Linux
	</td>
	<td>
		<p>
			Principia is available in the AUR. Build manually with <code>makepkg -si</code> or use your favourite AUR helper to install Principia.
		</p>

		<ul>
			<li>
				<a href="https://aur.archlinux.org/packages/principia"><code>principia</code></a> - stable release
			</li>
			<li>
				<a href="https://aur.archlinux.org/packages/principia-git"><code>principia-git</code></a> - latest master branch
			</li>
		</ul>

		<p>
			A <a href="https://arch.principia-web.se/">custom binary repository</a> is also available which contains prebuilt versions of the following packages. To add:
		</p>

		<p><code>echo -e '\n[principia]\nSigLevel = Optional DatabaseOptional\nServer = https://arch.principia-web.se/$arch' | sudo tee -a /etc/pacman.conf</code></p>
	</td>
</tr>

<tr>
	<td class="plat" id="nixos">
		<a href="#nixos"><img src="/icons/nix.svg"></a><br>NixOS
	</td>
	<td>
		<p>
			A package for Principia <a href="https://search.nixos.org/packages?channel=unstable&show=principia">is available in nixpkgs</a>.
		</p>
	</td>
</tr>

<tr>
	<td class="plat" id="alpine">
		<a href="#alpine"><img src="/icons/alpine.svg"></a><br>Alpine
	</td>
	<td>
		<p>
			A package for Principia <a href="https://pkgs.alpinelinux.org/packages?name=principia&branch=edge&arch=">is available in the testing repository of Alpine edge</a>.
		</p>
	</td>
</tr>

<tr>
	<td class="plat" id="slackware">
		<a href="#slackware"><img src="/icons/slackware.svg"></a><br>Slackware
	</td>
	<td>
		<p>
			A package for Principia <a href="https://slackbuilds.org/repository/15.0/games/principia/">is available in SlackBuilds</a>.
		</p>
	</td>
</tr>

<tr>
	<td class="plat" id="generic-linux">
		<div class="generic">?</div> <br>Other
	</td>
	<td>
		<p>
			<strong>
				<a href="https://github.com/Bithack/principia/archive/refs/tags/{{ version }}.tar.gz">
					Principia {{ version }} source code (.tar.gz)
				</a>
			</strong>
		</p>

		<p>
			Compilation instructions can be found on the
			<a href="/wiki/Compiling_Principia">Compiling Principia</a> wiki page.
		</p>

		<p>
			Alternatively clone the source repository and build from source <strong>(this will clone latest master)</strong>:
		</p>

		<p><code>git clone --depth 1 https://github.com/Bithack/principia</code></p>
	</td>
</tr>

<tr>
	<td class="plat" id="web">
		<a href="#web"><img src="/icons/chrome.svg"></a><br>Web
	</td>
	<td colspan="2">
		<p>
			Principia can run in your web browser now!
		</p>

		<p>
			The web version of Principia is still experimental, but you can play any level from the community site with the "Play in browser <span class="beta">(BETA)</span>" link under the level thumbnail, directly in your web browser without downloading anything.
		</p>
	</td>
</tr>

<tr>
	<td class="plat" id="macos">
		<a href="#macos">{{ icon("apple") }}</a><br>macOS
	</td>
	<td colspan="2">
		<p>
			A very experimental port to macOS is available for Principia.
			If you have Mac hardware and are willing to test if Principia works on macOS this would be very appreciated.
		</p>

		<p>
			Nightly builds for macOS are built on every commit which you can
			<a href="https://nightly.link/Bithack/principia/workflows/macos/master/principia-macos.zip">download from here</a>.
			Alternatively compile from source with the instructions found at <a href="/wiki/Compiling_Principia#macos">Compiling Principia</a>.
		</p>
	</td>
</tr>

<tr>
	<td class="plat" id="haiku">
		<a href="#haiku"><img src="/icons/haiku.svg"></a><br>Haiku
	</td>
	<td colspan="2">
		<p>
			An experimental port to Haiku OS is available for Principia.
		</p>

		<p>
			For instructions on how to compile and run Principia on Haiku OS see
			<a href="/wiki/Compiling_Principia#haiku-os">Compiling Principia</a>.
		</p>
	</td>
</tr>

<tr>
	<td class="plat" id="winxp">
		<a href="#winxp"><img src="/icons/windows_colorful.svg"></a><br>WinXP
	</td>
	<td colspan="2">
		<p>
			There are experimental builds of Principia that should run on Windows XP, both 32-bit and 64-bit editions.
		</p>

		<p>
			<a href="https://github.com/rollerozxa/principia-xp/releases">Principia for Windows XP releases</a>
		</p>

		<p>
			Note these builds are not officially maintained and use the experimental Dear Imgui dialog backend, which may still have issues.
		</p>
	</td>
</tr>

<tr>
	<td class="plat" id="nightly">
		<a href="#nightly">{{ icon("wizard-hat") }}</a><br>Nightly
	</td>
	<td colspan="2">
		<p>
			Whenever a new commit is pushed the game is automatically built by CI for all supported platforms.
			These nightly builds contain changes that have not yet made it into a full release,
			but are also less tested than the release builds.
		</p>

		<p>
			For more information and downloads see the <a href="/wiki/Nightly_Builds">Nightly Builds</a> page.
		</p>
	</td>
</tr>

<tr>
	<td class="plat" id="source">
		<a href="#source">{{ icon("root") }}</a><br>Source
	</td>
	<td colspan="2">
		<p>
			The source code for Principia is hosted on <a href="https://github.com/Bithack/principia">Github</a>
			with a read-only mirror available on <a href="https://codeberg.org/principia/principia">Codeberg</a>.
		</p>

		<p>
			For instructions on how to compile Principia from source see the
			<a href="/wiki/Compiling_Principia">Compiling Principia</a> page on the Principia Wiki.
		</p>
	</td>
</tr>

</table>

<p>For an archive of old Principia versions prior to the open sourcing, as well as Apparatus and Tesla Plushies, see the <a href="https://docs.google.com/spreadsheets/d/1G2YX0BV9_FSrIOvbCQtgYLE1XirCr8UaAfXUzuxjefE/htmlview">Bithack Game Archive Index</a>.</p>

<div style="height:100px"></div>

	{% endblock %}
